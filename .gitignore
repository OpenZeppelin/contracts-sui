# Sui build artifacts
build
.sui/
sui.keystore
.trace
.coverage_map.mvcov
traces/

# Local node publish artifact
Pub.local.toml

# OS generated files
.DS_Store
._*
.fuse_hidden*

# Logs
*.log
logs/

# Node.js artifacts (package.json + lockfile are committed so the codegen
