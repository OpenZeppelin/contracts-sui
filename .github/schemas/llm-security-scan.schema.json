{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "scanned_commit", "findings"],
  "properties": {
    "summary": { "type": "string", "minLength": 1 },
    "scanned_commit": { "type": "string", "minLength": 7 },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "category", "confidence", "file", "line_hint", "title", "description", "recommendation"],
        "properties": {
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "category": { "type": "string", "enum": ["access_control", "authz", "injection", "crypto", "dependency", "secrets", "dos", "memory_safety", "logic", "configuration", "other"] },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "file": { "type": "string", "minLength": 1 },
          "line_hint": { "type": ["string", "null"] },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "recommendation": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
